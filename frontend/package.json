{
  "name": "celestique-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "echo 'Building frontend...' && mkdir -p dist && cp -r * dist/ 2>/dev/null || true",
    "test": "vitest run",
    "lint": "npx eslint src --ext .js"
  },
  "devDependencies": {
    "eslint": "^10.2.0",
    "jest": "^29.7.0",
    "vitest": "^1.5.0"
  },
  "vitest": {
    "test": {
      "globals": true,
      "environment": "node",
      "include": ["src/**/*.test.js"]
    }
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {}
  }
}
