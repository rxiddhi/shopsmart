{
    "family": "shopsmart-backend",
    "networkMode": "awsvpc",
    "containerDefinitions": [
        {
            "name": "shopsmart-backend",
            "image": "REPLACE_WITH_IMAGE_URL",
            "essential": true,
            "portMappings": [
                {
                    "containerPort": 3001,
                    "hostPort": 3001,
                    "protocol": "tcp"
                }
            ],
            "environment": [
                { "name": "NODE_ENV", "value": "production" },
                { "name": "PORT", "value": "3001" },
                { "name": "DATABASE_URL", "value": "REPLACE_WITH_RDS_URL" },
                { "name": "JWT_SECRET", "value": "REPLACE_WITH_SECURE_SECRET" },
                { "name": "REFRESH_TOKEN_SECRET", "value": "REPLACE_WITH_SECURE_SECRET" },
                { "name": "ALLOWED_ORIGINS", "value": "REPLACE_WITH_FRONTEND_URL" }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/shopsmart-backend",
                    "awslogs-region": "us-east-1",
                    "awslogs-stream-prefix": "ecs"
                }
            },
            "healthCheck": {
                "command": ["CMD-SHELL", "curl -f http://localhost:3001/health || exit 1"],
                "interval": 30,
                "timeout": 5,
                "retries": 3,
                "startPeriod": 60
            }
        }
    ],
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "256",
    "memory": "512",
    "executionRoleArn": "arn:aws:iam::593924793273:role/LabRole",
    "taskRoleArn": "arn:aws:iam::593924793273:role/LabRole"
}
